# Copy to .env.local for local dev and fill real values.
# On Vercel, set these in Project Settings → Environment Variables.

# Prisma — Postgres connection string
# Local dev:      postgresql://postgres:postgres@localhost:5432/gunit?schema=public
# Vercel Postgres: auto-populated when you attach the database (no action needed)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# Default admin credentials — only used by the seed script on first run.
# Change the password via the DB or a future password-change page.
DEFAULT_ADMIN_EMAIL="admin@gunitsecurity.com.au"
DEFAULT_ADMIN_PASSWORD="ChangeMe123!"
