# Copy to .env (or .env.local) and fill in real values for production.

# Prisma — SQLite for local dev. For production switch to Postgres:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public"
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# Default admin credentials — only used by the seed script on first run
DEFAULT_ADMIN_EMAIL="admin@gunitsecurity.com.au"
DEFAULT_ADMIN_PASSWORD="ChangeMe123!"
