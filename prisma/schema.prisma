// G Unit Security — database schema
// Postgres for production (Vercel Postgres or any compatible provider).
// Local dev can either hit a local Postgres instance or a Vercel branch DB.

generator client {
  provider      = "prisma-client-js"
  // `native` for local dev, `rhel-openssl-3.0.x` for Vercel serverless
  // (AWS Lambda / Amazon Linux 2023 with Node 20+).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (pgbouncer) for the app's runtime queries.
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection for migrations / `prisma db push` / seed,
  // which don't work well through a pooler.
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  EDITOR
}

enum ApplicationStatus {
  NEW
  REVIEWED
  INTERVIEWED
  REJECTED
  HIRED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteSettings {
  id           String   @id @default(cuid())
  companyName  String   @default("G Unit Security")
  tagline      String?
  phone        String
  email        String
  address      String
  hours        String?
  facebookUrl  String?
  instagramUrl String?
  linkedinUrl  String?
  twitterUrl   String?
  updatedAt    DateTime @updatedAt
}

model Service {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  shortDesc String
  longDesc  String
  icon      String
  imageUrl  String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@index([published])
}

model Industry {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  icon        String
  imageUrl    String?
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  company   String?
  quote     String
  rating    Int      @default(5)
  avatarUrl String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

model CoreValue {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

model HeroSlide {
  id          String   @id @default(cuid())
  headline    String
  subheadline String
  ctaText     String?
  ctaLink     String?
  imageUrl    String?
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

model Partner {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String?
  website   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  service   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read])
  @@index([createdAt])
}

model CareerApplication {
  id          String            @id @default(cuid())
  name        String
  email       String
  phone       String
  position    String
  resumeUrl   String?
  coverLetter String?
  status      ApplicationStatus @default(NEW)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([status])
  @@index([createdAt])
}
