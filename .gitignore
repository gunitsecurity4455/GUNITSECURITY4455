.next/
out/
next-env.d.ts

# Misc
.DS_Store
Thumbs.db
*.tsbuildinfo
*.pem

# Env files — `.env` is committed with non-secret defaults so the
# Prisma CLI can parse the schema during `next build` even when a
# deploy env forgets to set DATABASE_URL. Real secrets belong in
# `.env.local` (for dev) or the hosting provider's env settings (Vercel, etc).
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Vercel
.vercel

# Prisma — keep any accidental SQLite files out of git
prisma/*.db
prisma/*.db-journal

# Uploaded admin media (tracked in git for local dev; override per deploy)
# /public/uploads
